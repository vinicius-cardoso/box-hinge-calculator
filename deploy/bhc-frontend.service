[Unit]
Description=Box Hinge Calculator — frontend (estático na porta 5500)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/box-hinge-calculator
ExecStart=/usr/bin/python3 -m http.server 5500 --directory design --bind 0.0.0.0
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
